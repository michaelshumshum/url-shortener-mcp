{
    "name": "url-shortener-mcp",
    "version": "1.1.1",
    "description": "A URL shortener MCP server built with Express, Prisma, TypeScript, and SQLite",
    "main": "dist/src/index.js",
    "bin": {
        "url-shortener-mcp": "bin/url-shortener-mcp.js"
    },
    "files": [
        "bin/",
        "dist/",
        "generated/",
        "prisma/migrations/",
        "prisma/schema.prisma",
        "prisma.config.ts"
    ],
    "scripts": {
        "dev": "nodemon --watch 'src/**/*.ts' --exec 'ts-node' src/index.ts",
        "build": "tsc",
        "start": "node dist/src/index.js",
        "check": "biome check --write",
        "format": "biome format --write",
        "init-env": "./scripts/init_env.sh",
        "user:create": "tsx scripts/create-user.ts",
        "db:migrate": "prisma migrate dev",
        "db:generate": "prisma generate",
        "db:studio": "prisma studio",
        "test": "vitest run",
        "test:watch": "vitest",
        "test:ui": "vitest --ui",
        "test:coverage": "vitest run --coverage",
        "prepare": "[ -d .git ] && lefthook install || true",
        "prepublishOnly": "pnpm build"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/michaelshumshum/url-shortener-mcp.git"
    },
    "keywords": [],
    "author": "",
    "license": "MIT",
    "dependencies": {
        "@modelcontextprotocol/sdk": "^1.28.0",
        "@prisma/adapter-better-sqlite3": "^7.5.0",
        "@prisma/client": "^7.5.0",
        "@t3-oss/env-core": "^0.13.11",
        "better-sqlite3": "^12.8.0",
        "dotenv": "^17.3.1",
        "express": "^4.22.1",
        "express-async-errors": "^3.1.1",
        "express-rate-limit": "^8.3.1",
        "node-cron": "^4.2.1",
        "prisma": "^7.5.0",
        "zod": "^4.3.6"
    },
    "devDependencies": {
        "@biomejs/biome": "^2.4.9",
        "@commitlint/cli": "^20.5.0",
        "@commitlint/config-conventional": "^20.5.0",
        "@semantic-release/changelog": "^6.0.3",
        "@semantic-release/commit-analyzer": "^13.0.1",
        "@semantic-release/git": "^10.0.1",
        "@semantic-release/github": "^12.0.6",
        "@semantic-release/npm": "^13.1.5",
        "@semantic-release/release-notes-generator": "^14.1.0",
        "@types/better-sqlite3": "^7.6.13",
        "@types/express": "^5.0.6",
        "@types/node": "^25.5.0",
        "@types/node-cron": "^3.0.11",
        "@types/supertest": "^7.2.0",
        "@vitest/coverage-v8": "^4.1.1",
        "@vitest/ui": "^4.1.1",
        "lefthook": "^2.1.4",
        "nodemon": "^3.1.14",
        "semantic-release": "^25.0.3",
        "supertest": "^7.2.2",
        "ts-node": "^10.9.2",
        "tsx": "^4.21.0",
        "typescript": "^6.0.2",
        "vitest": "^4.1.1"
    },
    "pnpm": {
        "onlyBuiltDependencies": [
            "@prisma/engines",
            "esbuild",
            "prisma",
            "lefthook",
            "better-sqlite3"
        ]
    }
}
