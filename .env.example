# Database
# Path to the SQLite database file
DATABASE_URL="file:./prisma/database.db"

# Server
# Port the HTTP server listens on
PORT=3000

# Expiry job
# Cron schedule for the background job that purges expired URLs
# Default: every minute. Uses standard 5-field cron syntax.
# Examples:
#   "*/5 * * * *"  — every 5 minutes
#   "0 * * * *"    — every hour
#   "0 0 * * *"    — every day at midnight
EXPIRY_JOB_CRON="* * * * *"

# Maximum allowed expiry duration in seconds.
# URLs cannot be created with a TTL or expiresAt beyond this limit.
# Default: 86400 (1 day)
# Examples:
#   3600    — 1 hour
#   604800  — 1 week
#   2592000 — 30 days
MAX_EXPIRY_SECONDS=86400

# Node environment
# Set to "production" to disable the Prisma client singleton dev cache
NODE_ENV="development"


# To use HTTPS or not
HTTPS=false

# The hostname to use
HOSTNAME=localhost